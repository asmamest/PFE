{
  "name": "qsdid-storage-manager",
  "version": "1.0.0",
  "description": "Decentralized credential storage module using IPFS (Kubo v0.39) for the QSDID platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testTimeout=30000",
    "test:pq": "jest tests/pqIntegration.test.js --testTimeout=60000",
    "test:unit": "jest tests/unit --testTimeout=10000",
    "test:integration": "jest tests/integration --testTimeout=30000",
    "test:load": "node tests/load/load-test.js",
    "lint": "eslint src --fix",
    "verify-pq": "node -e \"import('./src/pqc/client.js').then(m => m.PQCClient.getInstance()).then(() => console.log('✅ PQ module ready')).catch(e => { console.error('❌ PQ module failed:', e.message); process.exit(1); })\""
  },
  "dependencies": {
    "@elastic/ecs-pino-format": "^1.5.0",
    "@helia/unixfs": "^3.0.0",
    "axios": "^1.6.0",
    "blake3": "^2.1.7",
    "cors": "^2.8.5",
    "dilithium-crystals": "^1.0.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "kubo-rpc-client": "^4.1.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.0",
    "qsdid-wasm": "file:../qsdid-wasm/pkg",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
